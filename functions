#!/usr/bin/env bash

ready-dokku() {
  "$DOKKU_READY_BIN" "$@"
}

ready-dokku-root() {
  if [[ "$(id -u)" -eq 0 ]]; then
    ready-dokku "$@"
    return 0
  fi

  command -v sudo >/dev/null 2>&1 || dokku_log_fail "Dokku plugin installation requires root privileges or sudo access."
  sudo -n true >/dev/null 2>&1 || dokku_log_fail "Dokku plugin installation requires root privileges. Re-run as root or configure passwordless sudo."
  sudo "$DOKKU_READY_BIN" "$@"
}

ready-trim() {
  local value="$*"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

ready-has-command() {
  local cmd="$1"
  local status=0
  local not_implemented="${DOKKU_NOT_IMPLEMENTED_EXIT:-10}"

  set +e
  ready-dokku "$cmd" >/dev/null 2>&1
  status="$?"
  set -e

  [[ "$status" -ne "$not_implemented" ]]
}

ready-assert-command() {
  local cmd="$1" purpose="$2"
  ready-has-command "$cmd" || dokku_log_fail "Missing Dokku command '${cmd}'${purpose:+ (${purpose})}."
}

ready-assert-domain-command() {
  if ready-has-command "domains:set" || ready-has-command "domains:add"; then
    return 0
  fi

  dokku_log_fail "Neither 'domains:set' nor 'domains:add' is available on this Dokku installation."
}

ready-prompt() {
  local label="$1" default_value="${2-}" answer

  if [[ -n "$default_value" ]]; then
    read -rp "$label [$default_value]: " answer
  else
    read -rp "$label: " answer
  fi

  answer="$(ready-trim "$answer")"
  if [[ -z "$answer" ]] && [[ -n "$default_value" ]]; then
    answer="$default_value"
  fi

  printf '%s' "$answer"
}

ready-prompt-required() {
  local label="$1" default_value="${2-}" answer

  while true; do
    answer="$(ready-prompt "$label" "$default_value")"
    if [[ -n "$answer" ]]; then
      printf '%s' "$answer"
      return 0
    fi

    dokku_log_warn "A value is required."
  done
}

ready-prompt-yes-no() {
  local label="$1" default_value="${2:-Y}" answer normalized

  while true; do
    read -rp "$label [$default_value]: " answer
    answer="$(ready-trim "$answer")"
    [[ -z "$answer" ]] && answer="$default_value"

    normalized="$(printf '%s' "$answer" | tr '[:upper:]' '[:lower:]')"
    case "$normalized" in
      y|yes) return 0 ;;
      n|no) return 1 ;;
      *)
        dokku_log_warn "Please answer yes or no."
        ;;
    esac
  done
}

ready-app-exists() {
  ready-dokku apps:exists "$1" >/dev/null 2>&1
}

ready-postgres-exists() {
  ready-dokku postgres:exists "$1" >/dev/null 2>&1
}

ready-normalize-space-list() {
  tr ' ' '\n' | sed '/^[[:space:]]*$/d'
}

ready-report-single-value() {
  local output status

  set +e
  output="$(ready-dokku "$@" 2>/dev/null)"
  status="$?"
  set -e

  [[ "$status" -eq 0 ]] || return "$status"

  if [[ "$output" == *:* ]]; then
    printf '%s\n' "$output" | sed -n 's/^[[:space:]]*[^:]*:[[:space:]]*//p' | head -n 1
    return 0
  fi

  printf '%s\n' "$output" | head -n 1
}

ready-app-domains() {
  local app="$1" value=""

  if ready-has-command "domains:report"; then
    value="$(ready-report-single-value domains:report "$app" --domains-app-vhosts 2>/dev/null || true)"
    if [[ -z "$value" ]]; then
      value="$(ready-dokku domains:report "$app" 2>/dev/null | sed -n 's/^[[:space:]]*Domains app vhosts:[[:space:]]*//p' | head -n 1)"
    fi
  elif ready-has-command "domains"; then
    value="$(ready-dokku domains "$app" 2>/dev/null | sed '/^[[:space:]]*$/d;/^----->/d;/^=====>/d')"
  fi

  printf '%s\n' "$value" | ready-normalize-space-list
}

ready-first-app-domain() {
  ready-app-domains "$1" | head -n 1
}

ready-app-ports() {
  local app="$1" value=""

  if ready-has-command "ports:report"; then
    value="$(ready-report-single-value ports:report "$app" --ports-map 2>/dev/null || true)"
    if [[ -z "$value" ]]; then
      value="$(ready-dokku ports:report "$app" 2>/dev/null | sed -n 's/^[[:space:]]*Port map:[[:space:]]*//p' | head -n 1)"
    fi
  elif ready-has-command "proxy:ports"; then
    value="$(ready-dokku proxy:ports "$app" 2>/dev/null | sed '/^[[:space:]]*$/d;/^----->/d;/^=====>/d')"
  fi

  printf '%s\n' "$value" | ready-normalize-space-list
}

ready-current-container-port() {
  local app="$1" mapping

  while read -r mapping; do
    [[ -z "$mapping" ]] && continue
    printf '%s' "$mapping" | awk -F: '{print $3}'
    return 0
  done < <(ready-app-ports "$app")

  return 1
}

ready-letsencrypt-active() {
  local app="$1"
  local value=""
  local status=0

  if ready-has-command "letsencrypt:report"; then
    value="$(ready-report-single-value letsencrypt:report "$app" --letsencrypt-active 2>/dev/null || true)"
    if [[ -z "$value" ]]; then
      value="$(ready-dokku letsencrypt:report "$app" 2>/dev/null | sed -n 's/^[[:space:]]*Letsencrypt active:[[:space:]]*//p' | head -n 1)"
    fi
    [[ "$value" == "true" ]]
    return $?
  fi

  if ready-has-command "letsencrypt:active"; then
    set +e
    value="$(ready-dokku letsencrypt:active "$app" 2>/dev/null | tr -d '\r\n')"
    status="$?"
    set -e

    [[ "$value" == "true" ]] && return 0
    [[ "$status" -eq 0 ]] && [[ "$value" != "false" ]] && return 0
  fi

  return 1
}

ready-postgres-links() {
  local service="$1"

  ready-has-command "postgres:links" || return 0
  ready-dokku postgres:links "$service" 2>/dev/null | sed '/^[[:space:]]*$/d;/^----->/d;/^=====>/d' | awk '{print $1}'
}

ready-postgres-service-link-count() {
  local service="$1"
  local count=0 link

  while read -r link; do
    [[ -n "$link" ]] && count=$((count + 1))
  done < <(ready-postgres-links "$service")

  printf '%s' "$count"
}

ready-postgres-linked-to-app() {
  local service="$1" app="$2"

  if ready-has-command "postgres:linked"; then
    ready-dokku postgres:linked "$service" "$app" >/dev/null 2>&1
    return $?
  fi

  ready-postgres-links "$service" | grep -qx "$app"
}

ready-postgres-choose-service() {
  local requested_service="$1" app="$2" explicit="$3"
  local service="$requested_service"
  local suffix=1

  while ready-postgres-exists "$service"; do
    if ready-postgres-linked-to-app "$service" "$app"; then
      printf '%s' "$service"
      return 0
    fi

    if [[ "$(ready-postgres-service-link-count "$service")" -eq 0 ]]; then
      printf '%s' "$service"
      return 0
    fi

    if [[ "$explicit" == "true" ]]; then
      dokku_log_fail "Postgres service already exists and is linked elsewhere: $service"
    fi

    service="${requested_service}-${suffix}"
    suffix=$((suffix + 1))
  done

  printf '%s' "$service"
}

ready-removable-postgres-services() {
  local app="$1"
  local default_service="${app}-postgres"
  local service
  local seen=" "

  while read -r service; do
    [[ -z "$service" ]] && continue
    if [[ "$seen" != *" $service "* ]]; then
      echo "$service"
      seen="${seen}${service} "
    fi
  done < <(ready-linked-postgres-services "$app")

  if ready-postgres-exists "$default_service" && [[ "$(ready-postgres-service-link-count "$default_service")" -eq 0 ]] && [[ "$seen" != *" $default_service "* ]]; then
    echo "$default_service"
  fi
}

ready-summary-line-list() {
  local label="$1"
  shift
  local items=("$@")

  if [[ "${#items[@]}" -eq 0 ]]; then
    echo "${label}: none"
    return 0
  fi

  echo "${label}: ${items[*]}"
}

ready-app-delete-summary() {
  local app="$1"
  local domains=()
  local ports=()
  local postgres_services=()
  local line

  while read -r line; do
    [[ -n "$line" ]] && domains+=("$line")
  done < <(ready-app-domains "$app")

  while read -r line; do
    [[ -n "$line" ]] && ports+=("$line")
  done < <(ready-app-ports "$app")

  while read -r line; do
    [[ -n "$line" ]] && postgres_services+=("$line")
  done < <(ready-removable-postgres-services "$app")

  echo "App: $app"
  ready-summary-line-list "Domains" "${domains[@]}"
  ready-summary-line-list "Ports" "${ports[@]}"
  ready-summary-line-list "Postgres services" "${postgres_services[@]}"
  if ready-letsencrypt-active "$app"; then
    echo "SSL: active"
  else
    echo "SSL: inactive or unmanaged"
  fi
}

ready-plugin-installed() {
  local plugin_name="$1"

  if ready-has-command "plugin:installed"; then
    ready-dokku plugin:installed "$plugin_name" >/dev/null 2>&1
    return $?
  fi

  return 1
}

ready-install-plugin() {
  local plugin_name="$1" plugin_url="$2" command_name="$3"

  if ready-has-command "$command_name"; then
    return 0
  fi

  ready-assert-command "plugin:install" "automatic plugin installation"
  dokku_log_info1 "Installing Dokku plugin: $plugin_name"
  ready-dokku-root plugin:install "$plugin_url" --name "$plugin_name"
  ready-has-command "$command_name" || dokku_log_fail "Plugin installation completed but '${command_name}' is still unavailable."
}

ready-ensure-postgres-plugin() {
  if ready-has-command "postgres:create"; then
    return 0
  fi

  ready-install-plugin "postgres" "$DOKKU_READY_POSTGRES_PLUGIN_URL" "postgres:create"
}

ready-ensure-letsencrypt-plugin() {
  if ready-has-command "letsencrypt:enable"; then
    return 0
  fi

  ready-install-plugin "letsencrypt" "$DOKKU_READY_LETSENCRYPT_PLUGIN_URL" "letsencrypt:enable"

  if ready-has-command "letsencrypt:cron-job"; then
    set +e
    ready-dokku-root letsencrypt:cron-job --add >/dev/null 2>&1
    set -e
  fi
}

ready-validate-ipv4() {
  local ip="$1"
  local IFS=.
  local octets

  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
  read -r -a octets <<<"$ip"
  [[ "${#octets[@]}" -eq 4 ]] || return 1

  local octet
  for octet in "${octets[@]}"; do
    (( octet >= 0 && octet <= 255 )) || return 1
  done
}

ready-private-ipv4() {
  local ip="$1"

  [[ "$ip" =~ ^10\. ]] && return 0
  [[ "$ip" =~ ^127\. ]] && return 0
  [[ "$ip" =~ ^192\.168\. ]] && return 0
  [[ "$ip" =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]] && return 0
  [[ "$ip" =~ ^169\.254\. ]] && return 0
  return 1
}

ready-detect-public-ip() {
  local candidate=""

  if [[ -n "$DOKKU_READY_PUBLIC_IP" ]] && ready-validate-ipv4 "$DOKKU_READY_PUBLIC_IP"; then
    printf '%s' "$DOKKU_READY_PUBLIC_IP"
    return 0
  fi

  if command -v curl >/dev/null 2>&1; then
    for url in "https://api.ipify.org" "https://ifconfig.me/ip" "https://icanhazip.com"; do
      candidate="$(curl -fsS --max-time 5 "$url" 2>/dev/null | tr -d '\r\n')"
      if ready-validate-ipv4 "$candidate" && ! ready-private-ipv4 "$candidate"; then
        printf '%s' "$candidate"
        return 0
      fi
    done
  fi

  if command -v wget >/dev/null 2>&1; then
    for url in "https://api.ipify.org" "https://ifconfig.me/ip" "https://icanhazip.com"; do
      candidate="$(wget -qO- --timeout=5 "$url" 2>/dev/null | tr -d '\r\n')"
      if ready-validate-ipv4 "$candidate" && ! ready-private-ipv4 "$candidate"; then
        printf '%s' "$candidate"
        return 0
      fi
    done
  fi

  if command -v hostname >/dev/null 2>&1; then
    for candidate in $(hostname -I 2>/dev/null); do
      if ready-validate-ipv4 "$candidate" && ! ready-private-ipv4 "$candidate"; then
        printf '%s' "$candidate"
        return 0
      fi
    done
  fi

  return 1
}

ready-default-domain() {
  local app="$1" ip

  ip="$(ready-detect-public-ip)" || dokku_log_fail "Unable to determine a public IP for automatic sslip.io domain generation. Enter a domain manually or set DOKKU_READY_PUBLIC_IP."
  printf '%s.%s.sslip.io' "$app" "$ip"
}

ready-validate-port() {
  local port="$1"
  [[ "$port" =~ ^[0-9]+$ ]] || return 1
  (( port >= 1 && port <= 65535 ))
}

ready-prompt-port() {
  local default_port="${1-}"
  local port

  while true; do
    if [[ -n "$default_port" ]]; then
      port="$(ready-prompt-required "Container port" "$default_port")"
    else
      port="$(ready-prompt-required "Container port" "$DOKKU_READY_DEFAULT_PORT")"
    fi
    if ready-validate-port "$port"; then
      printf '%s' "$port"
      return 0
    fi

    dokku_log_warn "Port must be a number between 1 and 65535."
  done
}

ready-configure-domain() {
  local app="$1" domain="$2"

  if ready-has-command "domains:set"; then
    ready-dokku domains:set "$app" "$domain"
    return 0
  fi

  ready-assert-command "domains:add" "custom domain setup"
  ready-dokku domains:add "$app" "$domain"
}

ready-configure-proxy-ports() {
  local app="$1" container_port="$2"

  if ready-has-command "ports:set"; then
    ready-dokku ports:set "$app" "http:80:${container_port}" "https:443:${container_port}"
    return 0
  fi

  if ready-has-command "proxy:ports-set"; then
    ready-dokku proxy:ports-set "$app" "http:80:${container_port}" "https:443:${container_port}"
    return 0
  fi

  dokku_log_fail "Neither 'ports:set' nor 'proxy:ports-set' is available on this Dokku installation."
}

ready-try-enable-ssl() {
  local app="$1" email="$2" exit_code=0
  ready-ensure-letsencrypt-plugin

  if [[ -n "$email" ]]; then
    if ready-has-command "letsencrypt:set"; then
      ready-dokku letsencrypt:set "$app" email "$email"
    else
      dokku_log_warn "letsencrypt:set is unavailable, email was not configured automatically."
    fi
  fi

  dokku_log_warn "SSL activation may fail until the app is deployed and DNS is pointing to this Dokku server."
  set +e
  ready-dokku letsencrypt:enable "$app"
  exit_code="$?"
  set -e

  if [[ "$exit_code" -ne 0 ]]; then
    dokku_log_warn "SSL activation failed for now. Deploy the app, verify DNS, then rerun: dokku letsencrypt:enable $app"
  fi
}

ready-bootstrap-app-image() {
  local app="$1" container_port="$2"
  local tmp_dir

  tmp_dir="$(mktemp -d "/tmp/dokku-ready-${app}.XXXXXX")"
  trap 'rm -rf "$tmp_dir"' RETURN

  cat >"$tmp_dir/Dockerfile" <<EOF
FROM ${DOKKU_READY_BOOTSTRAP_BASE_IMAGE}
RUN apk add --no-cache busybox-extras
RUN mkdir -p /srv/www
RUN printf 'dokku ready bootstrap for ${app}\n' >/srv/www/index.html
ENV PORT=${container_port}
EXPOSE ${container_port}
CMD ["sh", "-c", "httpd -f -p \${PORT} -h /srv/www"]
EOF

  dokku_log_info1 "Deploying temporary bootstrap app"
  if ready-has-command "git:from-archive"; then
    (
      cd "$tmp_dir"
      tar -cf - .
    ) | ready-dokku git:from-archive "$app" -- "Dokku Ready" "ready@local"
    return 0
  fi

  if ready-has-command "tar:in"; then
    (
      cd "$tmp_dir"
      tar -cf - .
    ) | ready-dokku tar:in "$app"
    return 0
  fi

  dokku_log_fail "Neither 'git:from-archive' nor 'tar:in' is available on this Dokku installation."
}

ready-linked-postgres-services() {
  local app="$1"

  if ! ready-has-command "postgres:app-links"; then
    return 0
  fi

  ready-dokku postgres:app-links "$app" 2>/dev/null \
    | sed '/^[[:space:]]*$/d;/^----->/d;/^=====>/d' \
    | awk '{print $1}'
}

ready-first-linked-postgres-service() {
  ready-linked-postgres-services "$1" | head -n 1
}

ready-destroy-linked-postgres-services() {
  local app="$1" service
  local services=()
  
  while read -r service; do
    [[ -n "$service" ]] && services+=("$service")
  done < <(ready-removable-postgres-services "$app")

  for service in "${services[@]}"; do
    dokku_log_info1 "Removing postgres service: $service"

    if ready-has-command "postgres:linked" && ready-dokku postgres:linked "$service" "$app" >/dev/null 2>&1; then
      ready-dokku postgres:unlink "$service" "$app"
    fi

    ready-dokku postgres:destroy "$service" --force
  done
}
