#!/usr/bin/env bash
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/config"
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/functions"

cmd-ready-create() {
  #E interactively create a Dokku app with domain, ports, optional postgres and SSL
  #E dokku ready:create myapp
  #F --domain example.com, domain to assign without prompting
  #F --port 5000, container port for both http and https mappings
  #F --postgres, create and link a postgres service
  #F --no-postgres, skip postgres setup
  #F --postgres-service myapp-postgres, postgres service name
  #F --ssl, attempt letsencrypt enablement
  #F --no-ssl, skip ssl setup
  #F --email ops@example.com, letsencrypt email for the app
  declare desc="create an app with interactive Dokku bootstrap"
  local cmd="$PLUGIN_COMMAND_PREFIX:create" argv=("$@")
  [[ ${argv[0]} == "$cmd" ]] && shift 1

  local app="$1"
  local domain=""
  local container_port=""
  local postgres_mode=""
  local postgres_service=""
  local postgres_service_explicit="false"
  local ssl_mode=""
  local letsencrypt_email=""
  local app_exists="false"
  local current_domain=""
  local current_port=""
  local current_postgres_service=""

  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain)
        domain="$2"
        shift 2
        ;;
      --port)
        container_port="$2"
        shift 2
        ;;
      --postgres)
        postgres_mode="yes"
        shift 1
        ;;
      --no-postgres)
        postgres_mode="no"
        shift 1
        ;;
      --postgres-service)
        postgres_service="$2"
        postgres_service_explicit="true"
        shift 2
        ;;
      --ssl)
        ssl_mode="yes"
        shift 1
        ;;
      --no-ssl)
        ssl_mode="no"
        shift 1
        ;;
      --email)
        letsencrypt_email="$2"
        shift 2
        ;;
      *)
        dokku_log_fail "Unknown flag: $1"
        ;;
    esac
  done

  [[ -z "$app" ]] && dokku_log_fail "Please specify an app name: dokku ready:create <app>"
  if ready-app-exists "$app"; then
    app_exists="true"
    dokku_log_info1 "App already exists, continuing: $app"
    current_domain="$(ready-first-app-domain "$app" || true)"
    current_port="$(ready-current-container-port "$app" || true)"
    current_postgres_service="$(ready-first-linked-postgres-service "$app" || true)"
  fi

  if [[ -z "$domain" ]]; then
    if [[ -n "$current_domain" ]]; then
      domain="$(ready-prompt "Domain" "$current_domain")"
    else
      domain="$(ready-prompt "Domain (leave empty to generate an sslip.io domain)")"
    fi
    if [[ -z "$domain" ]]; then
      domain="$(ready-default-domain "$app")"
      dokku_log_info1 "Generated domain: $domain"
    fi
  fi

  if [[ -n "$container_port" ]]; then
    ready-validate-port "$container_port" || dokku_log_fail "Invalid container port: $container_port"
  else
    if [[ -n "$current_port" ]]; then
      container_port="$(ready-prompt-port "$current_port")"
    else
      container_port="$(ready-prompt-port)"
    fi
  fi

  if [[ -z "$postgres_mode" ]]; then
    if ready-prompt-yes-no "Install Postgres?" "Y"; then
      postgres_mode="yes"
    else
      postgres_mode="no"
    fi
  fi

  if [[ "$postgres_mode" == "yes" ]] && [[ -z "$postgres_service" ]]; then
    if [[ -n "$current_postgres_service" ]]; then
      postgres_service="$(ready-prompt-required "Postgres service name" "$current_postgres_service")"
    else
      postgres_service="$(ready-prompt-required "Postgres service name" "${app}-postgres")"
    fi
  fi

  if [[ -z "$ssl_mode" ]]; then
    if ready-prompt-yes-no "Attempt SSL setup?" "Y"; then
      ssl_mode="yes"
    else
      ssl_mode="no"
    fi
  fi

  if [[ "$ssl_mode" == "yes" ]] && [[ -z "$letsencrypt_email" ]]; then
    letsencrypt_email="$(ready-prompt "Let's Encrypt email (optional)")"
  fi

  ready-assert-command "apps:create" "app creation"
  ready-assert-command "apps:exists" "app existence checks"
  ready-assert-domain-command

  if [[ "$app_exists" != "true" ]]; then
    dokku_log_info1 "Creating app: $app"
    ready-dokku apps:create "$app"
  fi

  dokku_log_info1 "Configuring domain: $domain"
  ready-configure-domain "$app" "$domain"

  dokku_log_info1 "Mapping http/https to container port $container_port"
  ready-configure-proxy-ports "$app" "$container_port"

  if [[ "$ssl_mode" == "yes" ]]; then
    ready-ensure-letsencrypt-plugin
    if ready-letsencrypt-active "$app"; then
      dokku_log_info1 "SSL is already active, skipping bootstrap deploy"
    else
      ready-bootstrap-app-image "$app" "$container_port"
    fi
  fi

  if [[ "$postgres_mode" == "yes" ]]; then
    ready-ensure-postgres-plugin
    ready-assert-command "postgres:link" "postgres service linking"

    postgres_service="$(ready-postgres-choose-service "$postgres_service" "$app" "$postgres_service_explicit")"

    if ready-postgres-exists "$postgres_service"; then
      dokku_log_info1 "Reusing postgres service: $postgres_service"
    else
      dokku_log_info1 "Creating postgres service: $postgres_service"
      ready-dokku postgres:create "$postgres_service"
    fi

    if ready-postgres-linked-to-app "$postgres_service" "$app"; then
      dokku_log_info1 "Postgres service is already linked to app"
    else
      dokku_log_info1 "Linking postgres service to app"
      ready-dokku postgres:link "$postgres_service" "$app"
    fi
  fi

  if [[ "$ssl_mode" == "yes" ]]; then
    if ready-letsencrypt-active "$app"; then
      dokku_log_info1 "SSL is already active"
    else
      dokku_log_info1 "Attempting SSL enablement"
      ready-try-enable-ssl "$app" "$letsencrypt_email"
    fi
  fi

  dokku_log_info2 "ready:create completed for $app"
  echo "App: $app"
  echo "Domain: $domain"
  echo "Container port: $container_port"
  [[ "$postgres_mode" == "yes" ]] && echo "Postgres: $postgres_service"
  [[ "$ssl_mode" == "yes" ]] && echo "SSL: attempted"
}

cmd-ready-create "$@"
